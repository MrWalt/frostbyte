            img(src="img/the-void.png" style="width: 17em" draggable="false" class="user-select-none slider--img img--3 d-none")
            img(src="img/blizzard.png" style="width: 15em" draggable="false" class="user-select-none slider--img img--4 d-none")
            img(src="img/ferrari.png" style="width: 21.5em" draggable="false" class="user-select-none slider--img img--5 d-none")