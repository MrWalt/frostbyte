        h1(class="position-absolute bottom-0 end-0 fw-bold fs-1 me-4 mb-3 border-bottom border-5 rounded-1 user-select-none border-dark img--name img--name-1") Sienna
        h1(class="position-absolute bottom-0 end-0 fw-bold fs-1 me-4 mb-3 border-bottom border-5 rounded-1 user-select-none border-dark img--name img--name-2 d-none") Galaxy
        h1(class="position-absolute bottom-0 end-0 fw-bold fs-1 me-4 mb-3 border-bottom border-5 rounded-1 user-select-none border-dark img--name img--name-3 d-none") The Void
        h1(class="position-absolute bottom-0 end-0 fw-bold fs-1 me-4 mb-3 border-bottom border-5 rounded-1 user-select-none border-dark img--name img--name-4 d-none") Blizzard
        h1(class="position-absolute bottom-0 end-0 fw-bold fs-1 me-4 mb-3 border-bottom border-5 rounded-1 user-select-none border-dark img--name img--name-5 d-none") Rarri
