include includes/mixins.pug

doctype html
html(lang="en")
    head
        meta(charset="UTF-8")
        link(rel="icon", href="/src/img/favicon.ico", type = "image/png/svg")
        link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous")
        link(rel="stylesheet" href="style.css")
        script(defer src="scripts/computers.js")
        script(defer src="scripts/pcscript.js")
        title Frostbyte | Low-End
    body
        // Header and Nav bar
        include includes/nav.pug

        div(class="d-flex align-items-center justify-content-center hide--later")
            div(class="bg-light text-dark mt-5 border-dark ps-5 pe-5 pt-2 pb-2 border-start border-5 rounded-1") 
                h1(class="border-dark m-0 p-1 ps-4 pe-4 fw-bold computer--type") Low-End Builds
        
            // Modal View Window
        include includes/more-info.pug

            // Computers section
        div(class="d-flex align-items-center justify-content-center hide--later")
            section(class="p-5 position-relative" style="width: 1000px")
                div(class="position-absolute top-50 start-50 translate-middle")
                div(class="bg-light p-4 border-start border-5 border-dark rounded-1")
                    div(class="d-flex justify-content-evenly")
                        - const computersFirstRow = [{image: "img/prebuild-1.png", price: "299.99$", specs: "GTX 970 | Intel I3 3100", imgWidth: "width: 68%", data: 0}, {image: "img/prebuild-2.png", specs: "GTX 980 | Ryzen 3 2100", price: "349.99$", imgWidth: "width: 80%", data: 1}, {image: "img/prebuild-3.png", price: "399.99$", specs: "GTX 1050 | Ryzen 3 2900", imgWidth: "width: 80%", data: 2}]
                        each el in computersFirstRow
                            +computerDisplay(el)
                    div(class="d-flex justify-content-evenly mt-3")
                        - const computersSecondRow = [{image: "img/prebuild-4.png", price: "439.99$", specs: "GTX 1050Ti | Intel I3 6300", imgWidth: "width: 68%", data: 3}, {image: "img/prebuild-5.png", price: "469.99$", specs: "GTX 1060 | Ryzen 3 2900", imgWidth: "width: 80%", data: 4}, {image: "img/prebuild-6.png", price: "499.99$", specs: "GTX 1070 | Ryzen 3 3900", imgWidth: "width: 70.5%", data: 5}]
                        each el in computersSecondRow
                            +computerDisplay(el)

        // Featured Builds
        include includes/featured-slider.pug

        // Contact us
        include includes/contact-us.pug
        script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-MrcW6ZMFYlzcLA8Nl+NtUVF0sA7MsXsP1UyJoMp4YLEuNSfAP+JcXn/tWtIaxVXM" crossorigin="anonymous")